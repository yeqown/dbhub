{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DB Hub",
  "version": "1.4.2",
  "identifier": "com.dbhub.app",
  "build": {
    "frontendDist": "public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DB Hub",
        "label": "main",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' 'unsafe-hashes'; connect-src ipc: http://ipc.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon.png"
    ]
  }
}
