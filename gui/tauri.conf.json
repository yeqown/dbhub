{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "src-ui",
    "distDir": "src-ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "DB Hub",
    "version": "1.4.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "confirm": true,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "create": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["dmg"],
      "identifier": "com.dbhub.app",
      "icon": []
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"
    },
    "updater": {
      "active": false
    },
    "windows": [{
      "title": "DB Hub",
      "label": "main",
      "hidden": true
    }]
  }
}
