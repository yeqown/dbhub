{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for DB Hub GUI",
  "windows": ["main", "about", "manage"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    "shell:allow-open",
    "dialog:default"
  ]
}
